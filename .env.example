# Aiven MySQL Database Connection Credentials
# Copy this file to '.env' and fill in your actual credentials from Aiven console

DB_HOST=mysql-your-service-name.aivencloud.com
DB_PORT=24185
DB_NAME=defaultdb
DB_USER=avnadmin
DB_PASSWORD=your_aiven_password

# Optional SSL CA File Location (if you download Aiven's ca.pem certificate)
# DB_SSL_CA=C:\path\to\ca.pem
